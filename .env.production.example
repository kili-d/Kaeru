# Copy this to .env on your VPS before running docker compose.

APP_URL=https://kaeru.example.com
KAERU_PORT=5173
KAERU_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/kaeru:latest

# Replace this before hosting publicly.
SESSION_SECRET=replace-with-a-long-random-secret
KAERU_SETUP_TOKEN=replace-with-a-long-random-setup-token

# Keep registration closed unless you are intentionally onboarding users.
ALLOW_REGISTRATION=false
ENABLE_TOTP=false
LOG_LEVEL=info
