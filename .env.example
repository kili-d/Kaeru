# Kaeru local configuration
#
# The Node server reads these values when .env exists.

NODE_ENV=development
APP_URL=http://127.0.0.1:5173
HOST=127.0.0.1
PORT=5173

# SQLite is the preferred default for simple self-hosted VPS deployments.
DATABASE_URL=file:./data/kaeru.sqlite

# Reserved for stronger session signing and future auth hardening.
SESSION_SECRET=change-me-before-production

# Required for first-run setup only when NODE_ENV=production.
KAERU_SETUP_TOKEN=

# Disabled by default after first-run setup unless explicitly enabled.
ALLOW_REGISTRATION=false

# TOTP is planned, but not implemented yet.
ENABLE_TOTP=false

LOG_LEVEL=info
